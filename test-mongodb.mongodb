// MongoDB Playground - Sastro Jendro
// Use this file to test queries and collections

use("SastroJendro");

// Test 1: Check if database is connected
db.adminCommand({ ping: 1 });

// Test 2: Create collections if they don't exist
db.createCollection("members", {
  validator: {
    $jsonSchema: {
      bsonType: "object",
      required: ["email", "fullName", "username"],
      properties: {
        email: { bsonType: "string" },
        fullName: { bsonType: "string" },
        username: { bsonType: "string" }
      }
    }
  }
}).catch(() => console.log("Members collection exists"));

db.createCollection("articles").catch(() => console.log("Articles collection exists"));
db.createCollection("organization_structure").catch(() => console.log("Structure collection exists"));
db.createCollection("users").catch(() => console.log("Users collection exists"));

// Test 3: Create indexes
db.members.createIndex({ email: 1 }, { unique: true });
db.members.createIndex({ username: 1 }, { unique: true });
db.members.createIndex({ memberId: 1 });
db.articles.createIndex({ slug: 1 }, { unique: true });
db.users.createIndex({ email: 1 }, { unique: true });

console.log("✓ Database setup complete!");
